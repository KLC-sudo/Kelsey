# Railway Deployment Configuration Variables
# These environment variables must be configured in your Railway project settings

# 1. LiveKit configuration
# If hosting LiveKit on Railway, use the URL of that service. Otherwise use LiveKit Cloud URL.
LIVEKIT_URL=wss://your-livekit-url.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# 2. Database configuration
# No setup required for better-sqlite3 (it will automatically create server/kelsey.db)
# However, ensure that Railway has a Persistent Volume attached to the deployment
# mounted at the /app/server directory to prevent data loss on restarts.

# 3. Socket / Signaling URL
# Used by the Vite frontend to find the socket.io backend
# On Railway, VITE_SOCKET_URL should be the public URL of the deployed Express app
# Example: VITE_SOCKET_URL=https://kelsey-production.up.railway.app
VITE_SOCKET_URL=http://localhost:3001
VITE_SIGNALING_SERVER_URL=http://localhost:3001
