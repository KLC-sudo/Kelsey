  "grammarFocus": [
    {
      "name": "Verb 'sein' (to be)",
      "explanation": "The verb 'sein' is irregular and essential for identifying yourself and others. It corresponds to 'to be' in English.",
      "examples": [
        "Ich bin Lehrer (I am a teacher)",
        "Du bist freundlich (You are friendly)",
        "Er ist hier (He is here)",
        "Sie ist Maria (She is Maria)"
      ],
      "commonMistakes": [
        "Confusing 'bin' and 'bist' (e.g., saying 'du bin' instead of 'du bist')",
        "Lowercase 'Ich' (In German, 'ich' is only capitalized at the start of a sentence, unlike the English 'I')"
      ]
    },
    {
      "name": "Personal Pronouns (Singular)",
      "explanation": "Personal pronouns replace nouns. In A1.1, we focus on the singular forms used for direct address and description.",
      "examples": [
        "Ich (I)",
        "Du (You - informal)",
        "Er (He)",
        "Sie (She)"
      ],
      "commonMistakes": [
        "Using 'du' for formal situations (social mistake)",
        "Confusing 'sie' (she) with 'Sie' (formal you)"
      ]
    }
  ],
